# Copy to .env and adjust for your machine, then load it before serving
# (e.g. `export $(grep -v '^#' .env | xargs)` or via your web server config).

DB_HOST=localhost
DB_NAME=e_learning_db
DB_USER=root
DB_PASS=

# Note: database/learning.sql imports into whichever database you select.
# Create it first, e.g.:
#   mysql -u root -e "CREATE DATABASE e_learning_db"
#   mysql -u root e_learning_db < database/learning.sql
